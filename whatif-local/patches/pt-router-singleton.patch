+ along with this program.  If not, see <http://www.gnu.org/licenses/>. */
+package com.dashboard.servlet;
+
+import javax.servlet.ServletContextEvent;
+import javax.servlet.ServletContextListener;
+
+/**
+ * Builds the cached PT router at webapp startup so the one-time ~2GB GTFS graph load happens during
+ * container boot instead of on the first user's request. Registered in web.xml.
+ */
+public class PtWarmupListener implements ServletContextListener {
+
+    @Override
+    public void contextInitialized(ServletContextEvent sce) {
+        System.out.println("PtWarmupListener: warming up PT router (loading GTFS graph)...");
+        try {
+            Servlet.getPtRouter();   // blocks once; every later PT request reuses the cached instance
+            System.out.println("PtWarmupListener: PT router ready.");
+        } catch (Throwable t) {
+            // Do not block webapp startup on a warmup failure; the first PT request will retry.
+            System.out.println("PtWarmupListener: warmup failed, will build lazily on first request: " + t);
+            t.printStackTrace();
+        }
+    }
+
+    @Override
+    public void contextDestroyed(ServletContextEvent sce) {
+    }
+}
diff --git a/src/main/java/com/dashboard/servlet/Servlet.java b/src/main/java/com/dashboard/servlet/Servlet.java
index e32700e..b401582 100644
--- a/src/main/java/com/dashboard/servlet/Servlet.java
+++ b/src/main/java/com/dashboard/servlet/Servlet.java
@@ -48,6 +48,30 @@ public class Servlet {
     private static String _datareaderFile = "centro-latest.osm.pbf";
     private static final ZoneId _zoneId = ZoneId.of("Europe/Rome");
 
+    // Cached PT engine. Building it means loading the whole ~2GB GTFS graph-cache into the heap
+    // and importing the translation map, which takes minutes; doing it per request made a single
+    // route take 125-293s. The router is date-independent (the query date only enters the Request
+    // in getGtfsRoute), so it is safe to build once and reuse for the lifetime of the webapp.
+    private static volatile GraphHopperGtfs PT_HOPPER;
+    private static volatile PtRouter PT_ROUTER;
+
+    /**
+     * Lazily build and cache the PT router (double-checked locking so concurrent requests and the
+     * startup warmup listener build it exactly once). Reused across all PT requests.
+     */
+    static PtRouter getPtRouter() {
+        if (PT_ROUTER == null) {
+            synchronized (Servlet.class) {
+                if (PT_ROUTER == null) {
+                    GraphHopperConfig config = createConfig();
+                    PT_HOPPER = (GraphHopperGtfs) initGHGtfs(config);
+                    PT_ROUTER = initPtRouter(config, PT_HOPPER);
+                }
+            }
+        }
+        return PT_ROUTER;
+    }
+
     /**
      * API interface method called by Dashboard
      *
@@ -110,9 +134,8 @@ public class Servlet {
 
             if (routing.equals("pt") || routing.equals("public_transport") || vehicle.equals("bus")) {
                 routing = "pt";
-                GraphHopperConfig config = createConfig();
-                hopper = initGHGtfs(config);
-                PtRouter ptRouter = initPtRouter(config, (GraphHopperGtfs) hopper);
+                PtRouter ptRouter = getPtRouter();   // cached: builds the ~2GB graph once, reused
+                hopper = PT_HOPPER;                  // buildFormattedResponse casts this to GraphHopperGtfs for legs
                 response = getGtfsRoute(ptRouter, waypointsArray, startDatetime);
             } else {
                 hopper = initGH(vehicle, weighting, startDatetime);
@@ -123,9 +146,7 @@ public class Servlet {
             }
 
