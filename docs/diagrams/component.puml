@startuml component
!pragma layout smetana
title snap4city-mobility-mcp — Diagramma dei componenti

skinparam componentStyle rectangle
skinparam shadowing false

actor "Utente" as user

package "Frontend (Snap4City dashboard)" {
  [Chat box\n(widgetExternalContent)] as chat
  [Mappa (widgetMap)] as map
}

package "Bridge — api.py (FastAPI)" {
  [Job + Poll\nPOST /advise · GET /advise/{job_id}] as bridge
}

package "Orchestrator — Langgraph (orchestrator.py)" {
  [understand] as understand
  [execute] as execute
  [respond] as respond
}

package "Client MCP layer (mcp_tools.py)" {
  [exec_tool · two-pass geocode] as mcptools
}

cloud "Server Snap4City — MCP mobility\nsnap4agentic-mobility-advisor (mcp_server.py)" {
  [address_search_location\n(forward geocode)] as geocode
  [route (foot / car / bus)] as route
  [gtfs_shapes] as gtfs
}

cloud "LLM" {
  [Llama4\nllama4-agentic-inference] as llm
}

cloud "Server Snap4City — MCP native advisor\nsnap4agentic_advisor_native" {
  [coordinates_to_address\n(reverse geocode)] as revgeo
  [service_search_near_gps_position\n(near search)] as near
  [service_info_dev\n(live parking)] as parking
}

cloud "km4city / Snap4City (pubblici)" {
  [ServiceMap] as servicemap
  [What-If GraphHopper router] as whatif
  [tpl GTFS API] as tpl
}

user --> chat
chat --> bridge : HTTP (JSON)
chat ..> map : disegna wkt / legs
bridge --> understand
understand --> execute
execute --> respond
respond --> bridge : widget JSON

understand --> llm : forced tool call\n(estrazione slot)
execute --> mcptools
mcptools --> geocode
mcptools --> route
mcptools --> revgeo
mcptools --> near
mcptools --> parking
geocode --> servicemap
route --> whatif
route --> gtfs
gtfs --> tpl
@enduml
