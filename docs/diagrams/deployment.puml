@startuml deployment
!pragma layout smetana
title Distribuzione — bridge sul JupyterHub, MCP sul server Snap4City

skinparam shadowing false

node "Browser (utente)" {
  artifact "Dashboard Snap4City\n(chat box + widgetMap)" as dash
}

node "Snap4City JupyterHub (rete interna)" {
  component "jupyter-server-proxy" as proxy
  node "env s4c (conda py3.11)" {
    component "Bridge uvicorn\napi:app :8010" as bridge
  }
}

node "Server Snap4City\n192.168.1.117:8000" as s4c {
  component "MCP mobility\nsnap4agentic-mobility-advisor\n(geocode + route + gtfs)" as mob
  component "MCP native advisor\nsnap4agentic_advisor_native\n(reverse geocode + near search)" as native
}

cloud "Servizi pubblici Snap4City / km4city" {
  component "What-If GraphHopper\nwhatif-router" as whatif
  component "km4city ServiceMap" as sm
  component "tpl GTFS API" as tpl
}

cloud "LLM" {
  component "llama4-agentic-inference" as llm
}

dash --> proxy : HTTP same-origin
proxy --> bridge
bridge --> mob : S4C_LOCAL_MCP_URL (URL fisso)
bridge --> native : apps.json discovery
bridge --> llm
mob --> whatif
mob --> sm
mob --> tpl
@enduml
